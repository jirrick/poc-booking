@page "/Inbox"
@model PocBooking.Api.Pages.InboxModel
@{
    ViewData["Title"] = "Received webhooks (Inbox)";
}
<div class="container mt-4">
    <h1>Received webhooks (Inbox)</h1>
    <p><a asp-page="/Index">Back</a></p>
    <p>Last notifications received by the POC. Optional: refresh the page to see new entries.</p>
    @if (Model.Items.Count == 0)
    {
        <p>No notifications yet. Send a message from the simulator to trigger a webhook.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Received</th>
                    <th>Type</th>
                    <th>Guest name</th>
                    <th>Confirmation #</th>
                    <th>Internal reservation ID</th>
                    <th>Internal guest ID</th>
                    <th>Message ID</th>
                    <th>Notification UUID</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Items)
                {
                    <tr>
                        <td>@row.ReceivedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@row.Type</td>
                        <td>@(row.GuestName ?? "–")</td>
                        <td>@(row.ConfirmationNumber ?? "–")</td>
                        <td><code>@(row.InternalReservationId?.ToString() ?? "–")</code></td>
                        <td><code>@(row.InternalGuestId?.ToString() ?? "–")</code></td>
                        <td><small>@row.MessageId</small></td>
                        <td><small>@row.NotificationUuid</small></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
