<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] – POC Booking</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f0f2f5; }
        .poc-navbar { background: linear-gradient(90deg, #0d6efd 0%, #6610f2 100%); }
        .poc-badge { font-size: .65rem; letter-spacing: .08em; vertical-align: middle; }
        .card { box-shadow: 0 2px 8px rgba(0,0,0,.08); }
        .mapping-card { border-left: 4px solid #0d6efd; background: #eef4ff; }
        .chat-bubble { max-width: 70%; }
        .chat-bubble.guest  { background: #fff; border: 1px solid #dee2e6; }
        .chat-bubble.hotel  { background: #d1e7ff; }
        .msg-meta { font-size: .75rem; color: #6c757d; }
    </style>
</head>
<body>
    <nav class="poc-navbar navbar mb-4 px-3 py-2">
        <a class="navbar-brand text-white fw-bold" href="/Index">
            🏨 POC Booking
            <span class="badge bg-warning text-dark poc-badge ms-1">POC</span>
        </a>
        <div class="d-flex gap-3">
            <a class="text-white text-decoration-none small" href="/Conversations">Conversations</a>
            <a class="text-white text-decoration-none small" href="/Inbox">Inbox</a>
        </div>
    </nav>
    <div class="container pb-5">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
