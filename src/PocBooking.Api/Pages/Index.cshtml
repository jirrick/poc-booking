@page
@model PocBooking.Api.Pages.IndexModel
@{
    ViewData["Title"] = "POC Booking – Property";
}

<div class="row g-3 mt-1">
    <div class="col-md-6">
        <a asp-page="/Conversations" asp-route-propertyId="@Model.DefaultPropertyId" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">💬 Conversations</h5>
                    <p class="card-text text-muted small">Browse and reply to guest threads via the Booking API (simulator or real).</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6">
        <a asp-page="/Inbox" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">📬 Webhook Inbox</h5>
                    <p class="card-text text-muted small">CNS webhook notifications received by this service, enriched with internal guest and reservation mappings.</p>
                </div>
            </div>
        </a>
    </div>
</div>
