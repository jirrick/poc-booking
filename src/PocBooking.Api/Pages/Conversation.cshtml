@page "/Conversation"
@model PocBooking.Api.Pages.ConversationModel
@{
    ViewData["Title"] = "Conversation";
    var unreadGuestMessageIds = string.Join(",", Model.Messages
        .Where(m => m.SenderType == "guest" && !m.IsRead)
        .Select(m => m.MessageId));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-page="/Conversations" asp-route-propertyId="@Model.PropertyId" class="btn btn-outline-secondary btn-sm">← Conversations</a>
    <span class="text-muted small">ID: <code>@Model.ConversationId</code></span>
</div>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}
else
{
    <div class="row g-3">
        <!-- Local mapping card -->
        <div class="col-12">
            @if (Model.LocalMapping != null)
            {
                var m = Model.LocalMapping;
                <div class="card mapping-card mb-1">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex flex-wrap gap-4 align-items-start">
                            <div>
                                <div class="text-muted small text-uppercase fw-semibold">Guest</div>
                                <div class="fw-bold">@(m.GuestName ?? "–")</div>
                                @if (m.InternalGuestId.HasValue)
                                {
                                    <div class="text-muted small">Internal: <code>@m.InternalGuestId</code></div>
                                    <div class="text-muted small">Booking participant: <code>@m.BookingGuestId</code></div>
                                }
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase fw-semibold">Reservation</div>
                                <div class="fw-bold">@(string.IsNullOrEmpty(m.ConfirmationNumber) ? "–" : m.ConfirmationNumber)</div>
                                <div class="text-muted small">Internal: <code>@m.InternalReservationId</code></div>
                                <div class="text-muted small">Booking ref: <code>@m.BookingReservationId</code></div>
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase fw-semibold">Enterprise</div>
                                @if (Model.InternalEnterpriseId.HasValue)
                                {
                                    <div class="fw-bold"><code>@Model.InternalEnterpriseId</code></div>
                                }
                                else
                                {
                                    <div class="fw-bold text-muted">–</div>
                                }
                                <div class="text-muted small">Booking property: <code>@Model.PropertyId</code></div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning py-2 small mb-1">
                    No local mapping yet — send a message from the simulator to trigger the CNS webhook and populate the mapping.
                </div>
            }
        </div>

        <!-- Thread -->
        <div class="col-12">
            <div class="card">
                <div class="card-header py-2">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-semibold">Thread</span>
                            @if (!string.IsNullOrEmpty(Model.ConversationReference))
                            {
                                <span class="text-muted small">ref: <code>@Model.ConversationReference</code></span>
                            }
                            @if (Model.Access == "read_only")
                            {
                                <span class="badge bg-secondary">read-only</span>
                            }
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            @* no_reply_needed tag toggle *@
                            @if (Model.NoReplyNeeded)
                            {
                                <span class="badge bg-warning text-dark">🔕 No reply needed</span>
                                <form method="post" asp-page-handler="SetNoReplyNeeded"
                                      asp-route-propertyId="@Model.PropertyId"
                                      asp-route-conversationId="@Model.ConversationId"
                                      asp-route-value="false" class="d-inline">
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">Remove tag</button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted border">No tag</span>
                                <form method="post" asp-page-handler="SetNoReplyNeeded"
                                      asp-route-propertyId="@Model.PropertyId"
                                      asp-route-conversationId="@Model.ConversationId"
                                      asp-route-value="true" class="d-inline">
                                    <button type="submit" class="btn btn-outline-warning btn-sm">🔕 Mark no reply needed</button>
                                </form>
                            }
                            @* Mark all unread guest messages as read *@
                            @if (!string.IsNullOrEmpty(unreadGuestMessageIds) && !string.IsNullOrEmpty(Model.PropertyParticipantId))
                            {
                                <form method="post" asp-page-handler="MarkRead"
                                      asp-route-propertyId="@Model.PropertyId"
                                      asp-route-conversationId="@Model.ConversationId"
                                      asp-route-participantId="@Model.PropertyParticipantId"
                                      asp-route-messageIds="@unreadGuestMessageIds" class="d-inline">
                                    <button type="submit" class="btn btn-outline-primary btn-sm">✓ Mark all read</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-body d-flex flex-column gap-2" style="max-height:480px;overflow-y:auto;">
                    @if (!Model.Messages.Any())
                    {
                        <p class="text-muted small mb-0">No messages yet.</p>
                    }
                    @foreach (var msg in Model.Messages)
                    {
                        var isProperty = msg.SenderType == "property" || msg.SenderType == "hotel";
                        <div class="d-flex @(isProperty ? "justify-content-end" : "justify-content-start")">
                            <div class="chat-bubble @(isProperty ? "hotel" : "guest") rounded p-2" style="max-width:80%">
                                <div class="msg-meta mb-1 d-flex align-items-center gap-1 flex-wrap">
                                    <span class="badge @(isProperty ? "bg-secondary" : "bg-warning text-dark")" style="font-size:.65rem">@msg.SenderType</span>
                                    <span class="text-muted" style="font-size:.75rem">@msg.TimestampUtc.ToString("yyyy-MM-dd HH:mm") UTC</span>
                                    @if (msg.IsRead)
                                    {
                                        <span class="badge bg-success" style="font-size:.6rem" title="Read">✓✓ read</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border" style="font-size:.6rem">unread</span>
                                    }
                                </div>
                                <div>@msg.Content</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    @if (TempData["Success"] != null) { <div class="alert alert-success py-1 small mb-2">@TempData["Success"]</div> }
                    @if (TempData["Error"] != null) { <div class="alert alert-danger py-1 small mb-2">@TempData["Error"]</div> }
                    <form method="post" asp-page-handler="SendMessage"
                          asp-route-propertyId="@Model.PropertyId"
                          asp-route-conversationId="@Model.ConversationId">
                        <div class="input-group">
                            <textarea name="content" id="contentText" class="form-control" rows="2"
                                      placeholder="Reply as property…" required></textarea>
                            <button type="submit" class="btn btn-primary">Send</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
