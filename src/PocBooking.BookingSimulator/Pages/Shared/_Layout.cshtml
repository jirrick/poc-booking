<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] – Booking Simulator</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { background: #fffbf0; }
        .sim-navbar { background: linear-gradient(90deg, #fd7e14 0%, #dc3545 100%); }
        .sim-badge { font-size: .65rem; letter-spacing: .08em; vertical-align: middle; }
        .card { box-shadow: 0 2px 8px rgba(0,0,0,.08); }
        .guest-card { border-left: 4px solid #fd7e14; background: #fff8f0; }
        .chat-bubble { max-width: 70%; }
        .chat-bubble.guest  { background: #fff3cd; border: 1px solid #ffc107; }
        .chat-bubble.hotel  { background: #e9ecef; }
        .msg-meta { font-size: .75rem; color: #6c757d; }
    </style>
</head>
<body>
    <nav class="sim-navbar navbar mb-4 px-3 py-2">
        <a class="navbar-brand text-white fw-bold" href="/">
            🏨 Booking.com Simulator
            <span class="badge bg-warning text-dark sim-badge ms-1">SIM</span>
        </a>
        <a class="text-white text-decoration-none small ms-auto" href="/api-log">📋 API Log</a>
    </nav>
    <div class="container pb-5">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
