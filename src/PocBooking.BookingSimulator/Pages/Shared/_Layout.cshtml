<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Booking Simulator</title>
    <style>
        body { font-family: sans-serif; margin: 1rem 2rem; }
        a { color: #0066cc; }
        table { border-collapse: collapse; }
        th, td { border: 1px solid #ccc; padding: 0.5rem 0.75rem; text-align: left; }
        th { background: #f5f5f5; }
        .message { margin: 0.5rem 0; padding: 0.5rem; border-radius: 4px; max-width: 40rem; }
        .message.guest { background: #e3f2fd; }
        .message.hotel { background: #f5f5f5; margin-left: 1rem; }
        .meta { font-size: 0.85rem; color: #666; }
        form label { display: block; margin-top: 0.5rem; }
        form textarea { width: 100%; max-width: 30rem; min-height: 4rem; }
        form button { margin-top: 0.5rem; padding: 0.4rem 1rem; }
    </style>
</head>
<body>
    <header>
        <h1><a href="/">Booking.com Simulator</a></h1>
    </header>
    <main>
        @RenderBody()
    </main>
</body>
</html>
