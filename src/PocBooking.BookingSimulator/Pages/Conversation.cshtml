@page "/Conversation/{propertyId}/{conversationId}"
@model ConversationModel
@{
    ViewData["Title"] = "Conversation " + Model.ConversationId;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a href="/" class="btn btn-outline-secondary btn-sm">← Conversations</a>
    <div class="d-flex align-items-center gap-2">
        <span class="text-muted small"><strong>@Model.PropertyName</strong> · ref: <code>@Model.ConversationReference</code></span>
        @if (Model.NoReplyNeeded)
        {
            <span class="badge bg-warning text-dark">🔕 No reply needed</span>
        }
    </div>
</div>

@* Guest identity card *@
@if (Model.LinkedGuest != null)
{
    <div class="card guest-card mb-3">
        <div class="card-body py-2 px-3">
            <div class="d-flex gap-4 flex-wrap align-items-start">
                <div>
                    <div class="text-muted small text-uppercase fw-semibold">Guest (simulator participant)</div>
                    <div class="fw-bold">@Model.LinkedGuest.Name</div>
                    <div class="text-muted small">Participant ID: <code>@Model.LinkedGuest.ParticipantId</code></div>
                    <div class="form-text">This ID appears as <code>sender.participant_id</code> in CNS webhooks → maps to internal guest on POC side.</div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning py-2 small mb-3">
        No guest participant linked. Messages sent as "guest" will use any guest participant in the property.
        <a asp-page="/NewConversation" asp-route-propertyId="@Model.PropertyId" class="alert-link">Create a new conversation</a> to link a specific guest.
    </div>
}

<div class="card">
    <div class="card-header fw-semibold py-2">Thread</div>
    <div class="card-body d-flex flex-column gap-2" style="max-height:480px;overflow-y:auto;">
        @if (!Model.Messages.Any())
        {
            <p class="text-muted small mb-0">No messages yet.</p>
        }
        @foreach (var m in Model.Messages)
        {
            var isHotel = m.SenderType == "hotel";
            <div class="d-flex @(isHotel ? "justify-content-end" : "justify-content-start")">
                <div class="chat-bubble @(isHotel ? "hotel" : "guest") rounded p-2">
                    <div class="msg-meta mb-1 d-flex align-items-center gap-1 flex-wrap">
                        <strong>@m.SenderName</strong>
                        <span class="badge @(isHotel ? "bg-secondary" : "bg-warning text-dark") ms-1" style="font-size:.65rem">@m.SenderType</span>
                        <span class="text-muted" style="font-size:.75rem">· @m.TimestampUtc.ToString("HH:mm") UTC</span>
                        @if (m.IsRead)
                        {
                            <span class="badge bg-success" style="font-size:.6rem" title="Guest has read this">✓✓ read</span>
                        }
                        else if (isHotel)
                        {
                            <span class="badge bg-light text-muted border" style="font-size:.6rem">unread</span>
                        }
                    </div>
                    <div>@m.Content</div>
                </div>
            </div>
        }
    </div>
    <div class="card-footer">
        @if (TempData["Success"] is string ok) { <div class="alert alert-success py-1 small mb-2">@ok</div> }
        @if (TempData["Error"] is string err) { <div class="alert alert-danger py-1 small mb-2">@err</div> }
        <p class="text-muted small mb-2">Send as <strong>guest</strong> → POC receives CNS webhook + hotel messages marked read. Send as <strong>hotel</strong> → stored only (no webhook).</p>
        <form method="post" asp-page-handler="SendMessage"
              asp-route-propertyId="@Model.PropertyId"
              asp-route-conversationId="@Model.ConversationId">
            <div class="input-group">
                <select name="sendAs" class="form-select" style="max-width:160px">
                    <option value="guest">👤 Guest</option>
                    <option value="hotel">🏨 Hotel</option>
                </select>
                <textarea name="content" class="form-control" rows="2"
                          placeholder="Type message…" required></textarea>
                <button type="submit" class="btn btn-warning fw-semibold">Send</button>
            </div>
        </form>
    </div>
</div>
